{
  "name": "@sse/frontend-app",
  "private": true,
  "version": "2.2.1",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.app.json && vite build",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve-static": "node ../../scripts/frontend/storybook-static-server.mjs --root storybook-static --port 6007",
    "playwright:test": "node ../../scripts/frontend/run-playwright.mjs test --config playwright.config.ts",
    "tauri:dev": "cd ../../native/tauri-shell && tauri dev --features test-bridge",
    "tauri:build": "cd ../../native/tauri-shell && tauri build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@sse/design-system": "file:../packages/design-system",
    "@sse/engine-client": "file:../packages/engine-client",
    "@sse/shared-graphics": "file:../packages/shared-graphics",
    "@sse/test-fixtures": "file:../packages/test-fixtures",
    "@sse/tokens": "file:../packages/tokens",
    "@tauri-apps/api": "^2.11.0",
    "fuzzysort": "^3.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/react-vite": "^10.3.6",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
