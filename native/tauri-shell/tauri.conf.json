{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSE ExEd Studio Control",
  "version": "2.2.1",
  "identifier": "com.sse.exedstudiocontrol",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-command.mjs dev",
    "beforeBuildCommand": "node scripts/tauri-before-command.mjs build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../../frontend/app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SSE ExEd Studio Control",
        "width": 1600,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
