{
  "name": "sse-exed-studio-control",
  "version": "2.2.1",
  "description": "Native Tauri/Rust studio control console for a fixed SSE ExEd operator workstation.",
  "author": "Fikarn",
  "license": "MIT",
  "keywords": [
    "sse-exed-studio-control",
    "dmx",
    "osc",
    "stream-deck",
    "totalmix",
    "rme"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fikarn/sse-exed-studio-control.git"
  },
  "bugs": {
    "url": "https://github.com/Fikarn/sse-exed-studio-control/issues"
  },
  "homepage": "https://github.com/Fikarn/sse-exed-studio-control#readme",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "workspaces": [
    "frontend/app",
    "frontend/packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "clean:local": "node scripts/clean.mjs --local",
    "doctor": "node scripts/dev-doctor.mjs",
    "doctor:release": "node scripts/dev-doctor.mjs --release",
    "dev:check": "npm run format:check && npm run lint && npm run scripts:test && npm run file:health && npm run rust:fmt:check && npm run rust:clippy && npm run protocol:check && npm run frontend:typecheck && npm run native:check && npm run native:test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "scripts:test": "node --test scripts/disk-space.test.mjs scripts/qt-ifw-tools.test.mjs scripts/release/validate-release.test.mjs",
    "file:health": "node scripts/file-health.mjs",
    "rust:fmt:check": "cd native && cargo fmt --all -- --check",
    "rust:clippy": "cd native && cargo clippy --workspace --all-targets -- -D warnings",
    "protocol:generate": "node scripts/protocol/generate-protocol-artifacts.mjs",
    "protocol:check": "node scripts/protocol/generate-protocol-artifacts.mjs --check",
    "frontend:tokens:build": "npm run build --workspace frontend/packages/tokens",
    "frontend:typecheck": "npm run typecheck --workspaces --if-present",
    "frontend:storybook": "npm run storybook --workspace frontend/app",
    "frontend:storybook:build": "npm run storybook:build --workspace frontend/app",
    "frontend:fixtures:check": "npm run fixtures:check --workspace frontend/packages/test-fixtures",
    "frontend:playwright:test": "npm run build --workspace frontend/app && npm run playwright:test --workspace frontend/app",
    "frontend:foundation": "npm run protocol:generate && npm run frontend:tokens:build && npm run frontend:typecheck && npm run frontend:storybook:build && npm run frontend:fixtures:check && npm run frontend:playwright:test",
    "tauri:dev": "npm run tauri:dev --workspace frontend/app",
    "tauri:build": "npm run tauri:build --workspace frontend/app",
    "tauri:smoke": "node scripts/tauri-smoke.mjs",
    "tauri:foundation": "npm run protocol:generate && npm run native:engine:build && npm run tauri:build && npm run tauri:smoke",
    "tauri:setup-support:qualify": "npm run native:engine:build && node scripts/tauri-setup-support-qualification.mjs",
    "tauri:workspaces:qualify": "npm run native:engine:build && node scripts/tauri-workspace-qualification.mjs",
    "tauri:visual:review": "node scripts/tauri-visual-review.mjs",
    "tauri:cutover:candidate": "npm run protocol:check && npm run frontend:foundation && npm run tauri:foundation && npm run tauri:setup-support:qualify && npm run tauri:workspaces:qualify && npm run tauri:visual:review",
    "tauri:package:mac:local": "node scripts/legacy/tauri-package-candidate.mjs --target=macos",
    "tauri:package:mac:smoke": "node scripts/legacy/tauri-package-candidate.mjs --target=macos --smoke-test --smoke-scenarios=clean-start,dashboard",
    "tauri:smoke:mac": "npm run tauri:build && npm run tauri:package:mac:smoke",
    "tauri:installer:mac:prepare": "node scripts/legacy/tauri-candidate-ifw.mjs --target=macos --kind=installer --prepare-only",
    "tauri:installer:mac:local": "node scripts/legacy/tauri-candidate-ifw.mjs --target=macos --kind=installer",
    "tauri:update-repo:mac:prepare": "node scripts/legacy/tauri-candidate-ifw.mjs --target=macos --kind=update --prepare-only",
    "tauri:update-repo:mac:local": "node scripts/legacy/tauri-candidate-ifw.mjs --target=macos --kind=update",
    "tauri:artifacts:mac:staged-verify": "node scripts/legacy/verify-tauri-candidate-artifacts.mjs --target=macos --mode=staged",
    "tauri:artifacts:mac:verify": "node scripts/legacy/verify-tauri-candidate-artifacts.mjs --target=macos --mode=full",
    "tauri:installer-acceptance:mac:verify": "node scripts/native-installer-acceptance.mjs --target=macos --runtime=tauri",
    "tauri:package:mac:ifw-staged": "npm run tauri:package:mac:smoke && npm run tauri:installer:mac:prepare && npm run tauri:update-repo:mac:prepare && npm run tauri:artifacts:mac:staged-verify",
    "tauri:package:mac:ifw-local": "npm run tauri:package:mac:smoke && npm run tauri:installer:mac:local && npm run tauri:update-repo:mac:local && npm run tauri:artifacts:mac:verify && npm run tauri:installer-acceptance:mac:verify",
    "tauri:package:win:local": "node scripts/legacy/tauri-package-candidate.mjs --target=windows",
    "tauri:package:win:smoke": "node scripts/legacy/tauri-package-candidate.mjs --target=windows --smoke-test --smoke-scenarios=clean-start,dashboard",
    "tauri:smoke:win": "npm run tauri:build && npm run tauri:package:win:smoke",
    "tauri:installer:win:prepare": "node scripts/legacy/tauri-candidate-ifw.mjs --target=windows --kind=installer --prepare-only",
    "tauri:installer:win:local": "node scripts/legacy/tauri-candidate-ifw.mjs --target=windows --kind=installer",
    "tauri:update-repo:win:prepare": "node scripts/legacy/tauri-candidate-ifw.mjs --target=windows --kind=update --prepare-only",
    "tauri:update-repo:win:local": "node scripts/legacy/tauri-candidate-ifw.mjs --target=windows --kind=update",
    "tauri:artifacts:win:staged-verify": "node scripts/legacy/verify-tauri-candidate-artifacts.mjs --target=windows --mode=staged",
    "tauri:artifacts:win:verify": "node scripts/legacy/verify-tauri-candidate-artifacts.mjs --target=windows --mode=full",
    "tauri:installer-acceptance:win:verify": "node scripts/native-installer-acceptance.mjs --target=windows --runtime=tauri",
    "tauri:package:win:ifw-staged": "npm run tauri:package:win:smoke && npm run tauri:installer:win:prepare && npm run tauri:update-repo:win:prepare && npm run tauri:artifacts:win:staged-verify",
    "tauri:package:win:ifw-local": "npm run tauri:package:win:smoke && npm run tauri:installer:win:local && npm run tauri:update-repo:win:local && npm run tauri:artifacts:win:verify && npm run tauri:installer-acceptance:win:verify",
    "tauri:package:win:evidence": "node scripts/legacy/tauri-windows-target-evidence.mjs",
    "native:check": "cd native && cargo check --workspace",
    "native:test": "cd native && cargo test --workspace",
    "native:engine:build": "cd native && cargo build --package studio-control-engine",
    "native:shipping:build": "npm run native:engine:build && npm run tauri:build",
    "native:release:build": "node scripts/native-release-build.mjs",
    "native:release:win:evidence": "node scripts/native-windows-release-evidence.mjs",
    "native:package:mac:local": "node scripts/native-package.mjs --target=macos",
    "native:package:mac:smoke": "node scripts/native-package.mjs --target=macos --smoke-test",
    "native:package:mac:clean-smoke": "node scripts/native-package.mjs --target=macos --smoke-test --scenario=clean-start",
    "native:package:mac:acceptance": "node scripts/native-packaged-acceptance.mjs --target=macos",
    "native:bridge:mac:verify": "node scripts/native-control-surface-qualification.mjs --target=macos",
    "native:package:win:local": "node scripts/native-package.mjs --target=windows",
    "native:package:win:smoke": "node scripts/native-package.mjs --target=windows --smoke-test",
    "native:package:win:clean-smoke": "node scripts/native-package.mjs --target=windows --smoke-test --scenario=clean-start",
    "native:package:win:acceptance": "node scripts/native-packaged-acceptance.mjs --target=windows",
    "native:bridge:win:verify": "node scripts/native-control-surface-qualification.mjs --target=windows",
    "native:installer:mac:prepare": "node scripts/native-installer.mjs --target=macos --prepare-only",
    "native:installer:mac:local": "node scripts/native-installer.mjs --target=macos",
    "native:sign:mac:release": "node scripts/native-sign-macos.mjs",
    "native:sign:win:release": "node scripts/native-sign-windows.mjs",
    "native:installer:win:prepare": "node scripts/native-installer.mjs --target=windows --prepare-only",
    "native:installer:win:local": "node scripts/native-installer.mjs --target=windows",
    "native:update-repo:mac:prepare": "node scripts/native-update-repo.mjs --target=macos --prepare-only",
    "native:update-repo:mac:local": "node scripts/native-update-repo.mjs --target=macos",
    "native:update-repo:win:prepare": "node scripts/native-update-repo.mjs --target=windows --prepare-only",
    "native:update-repo:win:local": "node scripts/native-update-repo.mjs --target=windows",
    "native:checksums:mac:write": "node scripts/write-native-release-checksums.mjs --target=macos --mode=full",
    "native:checksums:mac:staged-write": "node scripts/write-native-release-checksums.mjs --target=macos --mode=staged",
    "native:checksums:win:write": "node scripts/write-native-release-checksums.mjs --target=windows --mode=full",
    "native:checksums:win:staged-write": "node scripts/write-native-release-checksums.mjs --target=windows --mode=staged",
    "native:artifacts:mac:verify": "node scripts/verify-native-release-artifacts.mjs --target=macos --mode=full",
    "native:artifacts:mac:staged-verify": "node scripts/verify-native-release-artifacts.mjs --target=macos --mode=staged",
    "native:artifacts:win:verify": "node scripts/verify-native-release-artifacts.mjs --target=windows --mode=full",
    "native:artifacts:win:staged-verify": "node scripts/verify-native-release-artifacts.mjs --target=windows --mode=staged",
    "native:continuity:mac:verify": "node scripts/verify-native-release-continuity.mjs --target=macos",
    "native:continuity:win:verify": "node scripts/verify-native-release-continuity.mjs --target=windows",
    "native:delivery:mac:verify": "node scripts/native-delivery-acceptance.mjs --target=macos",
    "native:delivery:win:verify": "node scripts/native-delivery-acceptance.mjs --target=windows",
    "native:installer-acceptance:mac:verify": "node scripts/native-installer-acceptance.mjs --target=macos",
    "native:installer-acceptance:win:verify": "node scripts/native-installer-acceptance.mjs --target=windows",
    "native:release:mac:local": "npm run native:release:build && npm run native:package:mac:smoke && npm run native:package:mac:clean-smoke && npm run native:package:mac:acceptance && npm run native:bridge:mac:verify && npm run native:installer:mac:local && npm run native:update-repo:mac:local && npm run native:checksums:mac:write && npm run native:artifacts:mac:verify && npm run native:continuity:mac:verify && npm run native:delivery:mac:verify && npm run native:installer-acceptance:mac:verify",
    "native:release:win:local": "npm run native:release:build && npm run native:package:win:smoke && npm run native:package:win:clean-smoke && npm run native:package:win:acceptance && npm run native:bridge:win:verify && npm run native:installer:win:local && npm run native:update-repo:win:local && npm run native:checksums:win:write && npm run native:artifacts:win:verify && npm run native:continuity:win:verify && npm run native:delivery:win:verify && npm run native:installer-acceptance:win:verify",
    "native:acceptance": "npm run native:engine:build && node scripts/native-acceptance.mjs",
    "native:shipping:foundation": "npm run native:check && npm run native:test && npm run tauri:foundation",
    "native:foundation": "npm run native:shipping:foundation",
    "ci": "npm run format:check && npm run release:check && npm run native:foundation",
    "release:check": "node scripts/release/validate-release.mjs",
    "release:anchor:verify": "node scripts/release/verify-release-anchor.mjs",
    "release:notes": "node scripts/release/write-release-notes.mjs",
    "release:publish": "node scripts/release/publish-release.mjs",
    "release:verify": "npm run release:check && npm run format:check && npm run native:check && npm run native:test && node scripts/release/verify-native-release.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,json,yml,yaml,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.10",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  }
}
